<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/scrollViewMore"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorSurface"
    android:clipToPadding="false"
    android:paddingBottom="@dimen/spacing_5xl"
    tools:context=".ui.fragments.MoreFragment">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="@dimen/spacing_lg"
        android:paddingTop="@dimen/spacing_2xl">

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="?attr/colorPrimaryContainer"
            app:cardCornerRadius="28dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/spacing_xl">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/more_hero_eyebrow"
                    android:textAppearance="?attr/textAppearanceLabelLarge"
                    android:textColor="?attr/colorOnPrimaryContainer" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_xs"
                    android:text="@string/more_hero_title"
                    android:textAppearance="?attr/textAppearanceHeadlineSmall"
                    android:textColor="?attr/colorOnPrimaryContainer" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_sm"
                    android:text="@string/more_hero_supporting_text"
                    android:textAppearance="?attr/textAppearanceBodyMedium"
                    android:textColor="?attr/colorOnPrimaryContainer" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:id="@+id/headerInfoText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingTop="@dimen/spacing_2xl"
            android:paddingBottom="@dimen/spacing_sm"
            android:textAppearance="?attr/textAppearanceLabelLarge"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:text="@string/more_header_info" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="?attr/colorSurfaceContainerHigh"
            app:cardCornerRadius="@dimen/card_corner_radius_meme"
            app:cardElevation="0dp"
            app:strokeWidth="0.5dp"
            app:strokeColor="?attr/colorOutlineVariant">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <include android:id="@+id/itemAppVersion" layout="@layout/list_item_view" />
                <View android:layout_width="match_parent" android:layout_height="0.5dp" android:background="?attr/colorOutlineVariant" android:layout_marginStart="56dp" />
                <include android:id="@+id/itemDeveloper" layout="@layout/list_item_view" />
                <View android:layout_width="match_parent" android:layout_height="0.5dp" android:background="?attr/colorOutlineVariant" android:layout_marginStart="56dp" />
                <include android:id="@+id/itemTotalMemes" layout="@layout/list_item_view" />
                <View android:layout_width="match_parent" android:layout_height="0.5dp" android:background="?attr/colorOutlineVariant" android:layout_marginStart="56dp" />
                <include android:id="@+id/itemSourceCode" layout="@layout/list_item_view" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:id="@+id/headerContributeText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingTop="@dimen/spacing_2xl"
            android:paddingBottom="@dimen/spacing_sm"
            android:textAppearance="?attr/textAppearanceLabelLarge"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:text="@string/more_header_contribute" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="?attr/colorSurfaceContainerHigh"
            app:cardCornerRadius="@dimen/card_corner_radius_meme"
            app:cardElevation="0dp"
            app:strokeWidth="0.5dp"
            app:strokeColor="?attr/colorOutlineVariant">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <include android:id="@+id/itemShareApp" layout="@layout/list_item_view" />
                <View android:layout_width="match_parent" android:layout_height="0.5dp" android:background="?attr/colorOutlineVariant" android:layout_marginStart="56dp" />
                <include android:id="@+id/itemReportBug" layout="@layout/list_item_view" />
                <View android:layout_width="match_parent" android:layout_height="0.5dp" android:background="?attr/colorOutlineVariant" android:layout_marginStart="56dp" />
                <include android:id="@+id/itemTranslate" layout="@layout/list_item_view" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:id="@+id/headerMoreText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingTop="@dimen/spacing_2xl"
            android:paddingBottom="@dimen/spacing_sm"
            android:textAppearance="?attr/textAppearanceLabelLarge"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:text="@string/more_header_more" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="?attr/colorSurfaceContainerHigh"
            app:cardCornerRadius="@dimen/card_corner_radius_meme"
            app:cardElevation="0dp"
            app:strokeWidth="0.5dp"
            app:strokeColor="?attr/colorOutlineVariant">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <include android:id="@+id/itemSettings" layout="@layout/list_item_view" />
                <View android:layout_width="match_parent" android:layout_height="0.5dp" android:background="?attr/colorOutlineVariant" android:layout_marginStart="56dp" />
                <include android:id="@+id/itemSocials" layout="@layout/list_item_view" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:id="@+id/headerUpdateText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingTop="@dimen/spacing_2xl"
            android:paddingBottom="@dimen/spacing_sm"
            android:textAppearance="?attr/textAppearanceLabelLarge"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:text="@string/more_header_update" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="?attr/colorSurfaceContainerHigh"
            app:cardCornerRadius="@dimen/card_corner_radius_meme"
            app:cardElevation="0dp"
            app:strokeWidth="0.5dp"
            app:strokeColor="?attr/colorOutlineVariant">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <include android:id="@+id/itemCheckForUpdate" layout="@layout/list_item_view" />

                <com.google.android.material.progressindicator.LinearProgressIndicator
                    android:id="@+id/progressBarAppInfo"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:indeterminate="true"
                    android:visibility="gone"
                    android:layout_marginHorizontal="@dimen/spacing_lg"
                    android:layout_marginBottom="@dimen/spacing_sm"
                    app:indicatorColor="?attr/colorPrimary"
                    tools:visibility="visible" />

                <LinearLayout
                    android:id="@+id/updateDetailsSection"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingHorizontal="@dimen/spacing_lg"
                    android:paddingTop="@dimen/spacing_sm"
                    android:paddingBottom="@dimen/spacing_lg"
                    android:visibility="gone"
                    tools:visibility="visible">

                    <TextView
                        android:id="@+id/textViewUpdateVersion"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textAppearance="?attr/textAppearanceTitleSmall"
                        android:textColor="?attr/colorPrimary"
                        tools:text="Version: 2.1.1" />

                    <TextView
                        android:id="@+id/textViewUpdateDate"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_xs"
                        android:textAppearance="?attr/textAppearanceBodySmall"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        tools:text="Released: 2025-05-01" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_lg"
                        android:text="@string/changelog_title"
                        android:textAppearance="?attr/textAppearanceLabelLarge"
                        android:textColor="?attr/colorOnSurface" />

                    <TextView
                        android:id="@+id/textViewChangelog"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_sm"
                        android:lineSpacingMultiplier="1.3"
                        android:textAppearance="?attr/textAppearanceBodyMedium"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        tools:text="• Improved performance\n• Added new meme filters\n• Fixed UI bugs in dark mode" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/buttonDownloadUpdate"
                        style="@style/Widget.Material3.Button.TonalButton"
                        android:layout_width="wrap_content"
                        android:layout_height="@dimen/button_height"
                        android:layout_gravity="end"
                        android:layout_marginTop="@dimen/spacing_lg"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        android:text="@string/download_update"
                        app:cornerRadius="@dimen/button_corner_radius" />

                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
